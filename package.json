{
  "name": "friday",
  "version": "0.1.0",
  "description": "Friday is a local-first AI development cockpit for planning, designing, building, and reviewing software with project memory, privacy-aware context handling, model routing, and cost control.",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "type": "module",
  "bin": {
    "friday": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MikeBlakeway/friday.git"
  },
  "keywords": [
    "ai",
    "developer-tools",
    "cli",
    "llm",
    "model-routing",
    "typescript",
    "agentic-workflows"
  ],
  "author": "Mike Blakeway",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MikeBlakeway/friday/issues"
  },
  "homepage": "https://github.com/MikeBlakeway/friday#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
